{
  "name": "photo-drop",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build:migrate": "esbuild src/db/migrate.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/migrate.cjs",
    "build:create-admin": "esbuild scripts/create-admin.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/create-admin.cjs",
    "create-admin": "tsx scripts/create-admin.ts",
    "dev:bucket": "tsx scripts/create-bucket.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.668.0",
    "@aws-sdk/s3-request-presigner": "^3.668.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "heic-convert": "^2.1.0",
    "jose": "^5.9.6",
    "next": "^15.3.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/heic-convert": "^2.1.1",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.28.1",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
