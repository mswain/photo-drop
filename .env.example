# ---------------------------------------------------------------------------
# Photo Drop — environment configuration
# Copy to .env and fill in. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# Postgres connection string used by the app and by Drizzle migrations.
DATABASE_URL=postgres://photo:photo@localhost:5432/photodrop

# Secret used to sign admin session cookies (JWT/HS256).
# Generate one with:  openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# ---- AWS / S3 ----
# Credentials used server-side to generate presigned upload/download URLs.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# Target bucket that photos are uploaded into.
S3_BUCKET=my-photo-drop-bucket

# Optional: point at an S3-compatible endpoint (MinIO, Cloudflare R2, etc.)
# Leave unset for real AWS S3.
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
#
# For local development, `make dev` runs a MiniStack S3 emulator and a Postgres
# container for you — see the Makefile. That dev stack uses:
#   S3_ENDPOINT=http://localhost:4566  S3_FORCE_PATH_STYLE=true
#   AWS_ACCESS_KEY_ID=test  AWS_SECRET_ACCESS_KEY=test

# Optional namespace prepended to every object key. Default (empty) stores each
# link's folder at the bucket root, e.g. "jims-wedding/<guid>.jpg". Set to e.g.
# "uploads/" to nest everything under one prefix ("uploads/jims-wedding/...").
# S3_KEY_PREFIX=

# ---- Upload constraints ----
# Max size per uploaded image in bytes (default 50 MiB).
MAX_UPLOAD_BYTES=52428800
# Max size per uploaded video in bytes (default 2 GiB). Videos are typically
# much larger than photos, so they get their own (higher) cap.
MAX_VIDEO_UPLOAD_BYTES=2147483648
# Comma-separated content-type prefixes uploads must match (default
# "image/,video/"). Use just "image/" to accept photos only.
ALLOWED_CONTENT_TYPE_PREFIX=image/,video/
# How long presigned URLs stay valid, in seconds (default 900 = 15 min).
PRESIGN_EXPIRY_SECONDS=900
# Longest edge (px) of generated preview thumbnails (default 600).
THUMBNAIL_MAX_PX=600

# Node environment (set to "production" in the container).
NODE_ENV=development
