# Use a flat (npm-style) node_modules layout. pnpm still hardlinks every
# package from the shared global store, so dependencies remain deduplicated and
# shared across projects — this only changes the on-disk layout.
#
# Required because drizzle-kit resolves `drizzle-orm` from its own scope, which
# pnpm's default isolated layout does not expose.
node-linker=hoisted
